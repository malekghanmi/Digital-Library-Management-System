@model BibliothequeFront.Models.CreateArticleViewModel
@{
    ViewData["Title"] = "Ajouter un Article";
}

<div class="page-container" style="max-width:750px;">
    <div style="margin-bottom:1.5rem;">
        <a asp-action="Index" class="btn-biblio btn-outline-biblio btn-sm-biblio">← Retour aux articles</a>
    </div>
    <div class="section-header">
        <h1 class="section-title">Ajouter un <span>Article</span></h1>
    </div>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="form-card">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.5rem;">
                <div class="form-group-biblio" style="grid-column:1/-1;">
                    <label class="form-label-biblio">Titre *</label>
                    <input asp-for="Titre" class="form-control-biblio" required />
                </div>
                <div class="form-group-biblio" style="grid-column:1/-1;">
                    <label class="form-label-biblio">Auteur(s) *</label>
                    <input asp-for="Auteur" class="form-control-biblio" required />
                </div>
                <div class="form-group-biblio">
                    <label class="form-label-biblio">Revue / Journal</label>
                    <input asp-for="Revue" class="form-control-biblio" placeholder="IEEE, Nature, CNRS…" />
                </div>
                <div class="form-group-biblio">
                    <label class="form-label-biblio">Année de publication</label>
                    <input asp-for="AnneePublication" type="number" class="form-control-biblio" min="1900" max="2100" />
                </div>
                <div class="form-group-biblio">
                    <label class="form-label-biblio">Domaine</label>
                    <input asp-for="Domaine" class="form-control-biblio" placeholder="Informatique, Médecine…" />
                </div>
                <div class="form-group-biblio">
                    <label class="form-label-biblio">DOI</label>
                    <input asp-for="DOI" class="form-control-biblio" placeholder="10.xxxx/xxxxx" />
                </div>
                <div class="form-group-biblio" style="grid-column:1/-1;">
                    <label class="form-label-biblio">Mots-clés (séparés par des virgules)</label>
                    <input asp-for="MotsCles" class="form-control-biblio" placeholder="machine learning, deep learning, NLP…" />
                </div>
                <div class="form-group-biblio" style="grid-column:1/-1;">
                    <label class="form-label-biblio">Lien d'accès</label>
                    <input asp-for="LienAcces" class="form-control-biblio" placeholder="https://doi.org/…" />
                </div>
                <div class="form-group-biblio" style="grid-column:1/-1;">
                    <label class="form-label-biblio">Résumé</label>
                    <textarea asp-for="Resume" class="form-control-biblio" rows="5" placeholder="Résumé de l'article…"></textarea>
                </div>
            </div>
            <div style="display:flex; gap:0.75rem; padding-top:1.5rem; border-top:1px solid rgba(201,168,76,0.15); margin-top:1rem;">
                <button type="submit" class="btn-biblio btn-primary-biblio">＋ Ajouter l'article</button>
                <a asp-action="Index" class="btn-biblio btn-outline-biblio">Annuler</a>
            </div>
        </div>
    </form>
</div>
